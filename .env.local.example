# ─────────────── Supabase ───────────────
# From Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Publishable key (safe to expose to browser, used by frontend + RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxx

# Service role / secret key (server-only — NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxx

# Project ref = the subdomain part of the URL above
SUPABASE_PROJECT_REF=buiefmgwzxpuxfshixas


# ─────────────── App ───────────────
# Local dev: http://localhost:3000
# Production: https://your-vercel-domain.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ─────────────── Cron ───────────────
# Used to authenticate Vercel Cron requests to /api/cron/*
# Generate locally: openssl rand -hex 32
# Mark as Sensitive in Vercel dashboard.
CRON_SECRET=replace-with-random-64-char-hex


# ─────────────── Observability ───────────────
LOG_LEVEL=info
