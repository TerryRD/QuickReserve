{
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "regions": ["sin1"],
  "crons": [
    {
      "path": "/api/cron/materialize-recurring",
      "schedule": "30 16 * * *"
    },
    {
      "path": "/api/cron/weekly-summary",
      "schedule": "0 12 * * 0"
    },
    {
      "path": "/api/cron/auto-cancel-group-class",
      "schedule": "0 0 * * *"
    }
  ]
}
